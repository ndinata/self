---
import type { HTMLAttributes } from "astro/types";

import { cn } from "@/styles/utils";

type Props = HTMLAttributes<"fieldset"> & {
  title?: string;
  id?: string;
};

const { title, id, class: propClass, ...props } = Astro.props;

const Legend = id ? "a" : "span";
---

<fieldset {...props} id={id} class={cn("border p-0", propClass)}>
  <legend class="ml-4 px-2"
    ><Legend
      href={`#${id}`}
      class={cn("text-lg font-medium", !!id && "hover:text-primary")}
      >{title}</Legend
    ></legend
  >
  <slot />
</fieldset>
